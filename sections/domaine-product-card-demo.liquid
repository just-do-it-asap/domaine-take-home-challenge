{% liquid
  assign demo_product = section.settings.product
  if demo_product == blank
    assign demo_product = all_products['classic-cotton-tee']
  endif
%}

<section class="domaine-scope bg-white px-5 py-12 sm:px-8 lg:px-12">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[620px_minmax(0,1fr)] lg:items-start">
    {% if demo_product != blank %}
      {% render 'domaine-product-card', product: demo_product %}

      {% if demo_product.variants.size > 1 %}
        <div class="min-w-0">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-normal text-zinc-500">
            Available variants
          </h2>

          <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3" role="list">
            {% for variant in demo_product.variants %}
              {% liquid
                assign variant_asset_position = forloop.index
                assign variant_shirt_asset = 'domaine-shirt-' | append: variant_asset_position | append: '.jpg'
                assign variant_model_asset = 'domaine-model-' | append: variant_asset_position | append: '.jpg'
                assign variant_media = variant.featured_media | default: demo_product.featured_media
                assign variant_image = variant_media.preview_image | default: demo_product.featured_image
                assign variant_on_sale = false
                if variant.compare_at_price > variant.price
                  assign variant_on_sale = true
                endif
              %}

              <li class="rounded-lg border border-zinc-200 bg-white p-3">
                <div class="grid aspect-square grid-cols-[0.9fr_1.1fr] items-end gap-2 overflow-hidden bg-white">
                  {% if variant_asset_position <= 6 %}
                    <img
                      class="h-full max-h-[78%] w-full self-center object-contain"
                      src="{{ variant_shirt_asset | asset_url }}"
                      alt="{{ variant.title | escape }} flat shirt"
                      width="360"
                      height="360"
                      loading="lazy"
                    >
                    <img
                      class="h-full w-full object-contain"
                      src="{{ variant_model_asset | asset_url }}"
                      alt="{{ variant.title | escape }} worn by model"
                      width="360"
                      height="360"
                      loading="lazy"
                    >
                  {% elsif variant_image %}
                    <img
                      class="col-span-2 h-full w-full object-contain"
                      src="{{ variant_image | image_url: width: 360 }}"
                      alt="{{ variant_image.alt | default: variant.title | escape }}"
                      width="360"
                      height="360"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="col-span-2 flex h-full w-full items-center justify-center text-zinc-300">
                      {{ 'product-1' | placeholder_svg_tag: 'h-full w-full' }}
                    </div>
                  {% endif %}
                </div>

                <div class="mt-3 grid gap-1">
                  <p class="text-sm font-medium leading-snug text-zinc-950">
                    {{ variant.title | escape }}
                  </p>
                  <p class="flex flex-wrap items-baseline gap-2 text-sm">
                    {% if variant_on_sale %}
                      <s class="text-zinc-500">{{ variant.compare_at_price | money }}</s>
                    {% endif %}
                    <span class="{% if variant_on_sale %}text-[#ff0000]{% else %}text-zinc-950{% endif %}">
                      {{ variant.price | money }}
                    </span>
                  </p>
                </div>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% else %}
      <div class="mx-auto max-w-[360px] rounded-lg border border-dashed border-zinc-300 p-6 text-sm text-zinc-600">
        Select a product in the theme editor or create a product with handle <strong>classic-cotton-tee</strong>.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Domaine product card demo",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
  ],
  "presets": [
    {
      "name": "Domaine product card demo",
      "category": "Products"
    }
  ]
}
{% endschema %}
